---
import { localBusinessVerticalList } from "@/data/local-business-content";
---

<section
  id="rubros"
  data-track-section="local_business_pathways"
  class="relative border-b border-white/10 bg-brand-black py-20 md:py-24"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-8 md:grid-cols-[0.78fr_1.22fr] md:items-end">
      <div class="max-w-xl">
        <h2 class="text-balance text-4xl font-bold leading-tight text-white md:text-5xl">
          Arrancamos por rubros donde una web bien hecha puede cerrar rapido.
        </h2>
      </div>
      <p class="max-w-2xl text-base leading-relaxed text-brand-off-white/72 md:justify-self-end md:text-lg">
        Cada landing habla el idioma del negocio: dolores reales, WhatsApp con
        contexto, rangos visibles y opcion de crecer hacia automatizacion.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {
        localBusinessVerticalList.map((vertical) => (
          <article class="group rounded-[1.75rem] border border-white/10 bg-white/[0.035] p-6 transition-colors duration-300 hover:border-brand-gold/40">
            <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
              <div>
                <h3 class="text-2xl font-bold leading-tight text-white">
                  {vertical.navLabel}
                </h3>
                <p class="mt-4 max-w-2xl text-sm leading-relaxed text-brand-off-white/70">
                  {vertical.heroDescription}
                </p>
              </div>
              <a
                href={vertical.route}
                data-track="vertical_view_click"
                data-track-label={vertical.navLabel}
                data-track-location="home_verticals"
                data-vertical={vertical.key}
                class="inline-flex min-h-11 shrink-0 items-center justify-center rounded-full border border-white/15 px-5 py-3 text-sm font-black uppercase tracking-[0.14em] text-white transition-colors duration-300 hover:border-brand-gold/60 hover:text-brand-gold"
              >
                Ver landing
              </a>
            </div>

            <div class="mt-6 grid gap-3 border-t border-white/10 pt-5">
              {vertical.visibleOutcomes.map((outcome) => (
                <p class="flex gap-3 text-sm leading-relaxed text-brand-off-white/70">
                  <span class="mt-1.5 size-2 shrink-0 rounded-full bg-brand-gold"></span>
                  <span>{outcome}</span>
                </p>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
