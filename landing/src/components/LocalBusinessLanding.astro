---
import TechAuthority from "@/components/TechAuthority.astro";
import WebPackages from "@/components/WebPackages.astro";
import type { LocalBusinessVertical } from "@/data/local-business-content";
import { createWhatsAppHref } from "@/lib/whatsapp";

interface Props {
  vertical: LocalBusinessVertical;
}

const { vertical } = Astro.props;
const heroHref = createWhatsAppHref(vertical.whatsappMessage);
---

<section
  data-track-section={`${vertical.key}_hero`}
  class="relative isolate overflow-hidden border-b border-white/10 bg-brand-black pt-28"
>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(212,175,55,0.17),transparent_34%),radial-gradient(circle_at_86%_22%,rgba(255,255,255,0.08),transparent_28%)]"></div>
  <div class="absolute inset-0 opacity-20 [background-image:linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.06)_1px,transparent_1px)] [background-size:38px_38px]"></div>

  <div class="relative mx-auto grid min-h-[calc(100svh-5rem)] max-w-7xl gap-10 px-6 pb-16 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
    <div class="max-w-2xl">
      <a
        href="/#rubros"
        class="text-sm font-semibold text-brand-gold/82 transition-colors hover:text-brand-gold"
      >
        Webs para negocios locales
      </a>
      <h1 class="mt-5 text-balance text-4xl font-bold leading-[1.02] text-white md:text-6xl">
        {vertical.heroTitle}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-brand-off-white/76 md:text-xl">
        {vertical.heroDescription}
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href={heroHref}
          target="_blank"
          rel="noopener noreferrer"
          data-track="whatsapp_click"
          data-track-label={vertical.primaryCtaLabel}
          data-track-location={`${vertical.key}_hero`}
          data-vertical={vertical.key}
          data-business-type={vertical.businessType}
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-gold-gradient px-7 py-4 text-center text-sm font-black uppercase tracking-[0.16em] text-black transition-transform duration-300 hover:scale-[1.02]"
        >
          {vertical.primaryCtaLabel}
        </a>
        <a
          href="#paquetes"
          data-track="package_anchor_click"
          data-track-label="Ver rangos"
          data-track-location={`${vertical.key}_hero`}
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/15 px-7 py-4 text-sm font-black uppercase tracking-[0.16em] text-white transition-colors duration-300 hover:border-brand-gold/60 hover:text-brand-gold"
        >
          Ver rangos
        </a>
      </div>
    </div>

    <div class="relative rounded-[2rem] border border-white/10 bg-white/[0.035] p-5 shadow-[0_32px_120px_rgba(0,0,0,0.42)]">
      <div class="rounded-[1.5rem] border border-white/10 bg-brand-black/80 p-5">
        <div class="flex items-center justify-between border-b border-white/10 pb-4">
          <div class="flex items-center gap-2">
            <span class="size-2.5 rounded-full bg-[#f87171]"></span>
            <span class="size-2.5 rounded-full bg-[#facc15]"></span>
            <span class="size-2.5 rounded-full bg-[#4ade80]"></span>
          </div>
          <span class="text-[10px] font-black uppercase tracking-[0.24em] text-brand-off-white/45">
            Flujo comercial
          </span>
        </div>

        <div class="mt-5 grid gap-4">
          {vertical.painPoints.map((point) => (
            <div class="rounded-[1.25rem] border border-white/10 bg-white/[0.035] px-4 py-3">
              <p class="text-sm leading-relaxed text-brand-off-white/76">{point}</p>
            </div>
          ))}
        </div>

        <div class="mt-5 rounded-[1.25rem] border border-brand-gold/20 bg-brand-gold/10 p-4">
          <p class="text-[10px] font-black uppercase tracking-[0.24em] text-brand-gold">
            Resultado buscado
          </p>
          <p class="mt-2 text-lg font-bold leading-snug text-white">
            Mas consultas utiles por WhatsApp, menos friccion antes de vender.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section
  data-track-section={`${vertical.key}_offer`}
  class="border-b border-white/10 bg-brand-black py-20"
>
  <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-[0.78fr_1.22fr]">
    <div class="max-w-md">
      <h2 class="text-balance text-4xl font-bold leading-tight text-white md:text-5xl">
        {vertical.offerTitle}
      </h2>
      <p class="mt-5 text-base leading-relaxed text-brand-off-white/72 md:text-lg">
        {vertical.offerSummary}
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {vertical.visibleOutcomes.map((outcome) => (
        <article class="border-t border-white/10 pt-5">
          <p class="text-base font-semibold leading-snug text-white">{outcome}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section
  data-track-section={`${vertical.key}_flow`}
  class="border-b border-white/10 bg-brand-charcoal/45 py-20"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">
      <div class="max-w-md">
        <h2 class="text-balance text-4xl font-bold leading-tight text-white md:text-5xl">
          {vertical.flowTitle}
        </h2>
      </div>
      <div class="grid gap-6">
        {vertical.flowSteps.map((step, index) => (
          <article class="grid gap-4 border-t border-white/10 pt-5 md:grid-cols-[72px_1fr]">
            <div class="text-3xl font-bold text-brand-gold/64">
              {(index + 1).toString().padStart(2, "0")}
            </div>
            <div>
              <h3 class="text-xl font-bold text-white">{step.title}</h3>
              <p class="mt-3 max-w-2xl text-sm leading-relaxed text-brand-off-white/68">
                {step.description}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<WebPackages location={`${vertical.key}_packages`} vertical={vertical.key} />

<section
  data-track-section={`${vertical.key}_proof`}
  class="border-b border-white/10 bg-brand-black py-20"
>
  <div class="mx-auto max-w-5xl px-6">
    <div class="rounded-[2rem] border border-brand-gold/20 bg-[linear-gradient(135deg,rgba(212,175,55,0.15),rgba(255,255,255,0.035))] px-8 py-10 md:px-12">
      <h2 class="max-w-3xl text-balance text-3xl font-bold leading-tight text-white md:text-5xl">
        {vertical.proofTitle}
      </h2>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-brand-off-white/74 md:text-lg">
        {vertical.proofBody}
      </p>
      <a
        href={heroHref}
        target="_blank"
        rel="noopener noreferrer"
        data-track="whatsapp_click"
        data-track-label={vertical.primaryCtaLabel}
        data-track-location={`${vertical.key}_final_cta`}
        data-vertical={vertical.key}
        class="mt-8 inline-flex min-h-12 items-center justify-center rounded-full bg-gold-gradient px-7 py-4 text-sm font-black uppercase tracking-[0.16em] text-black transition-transform duration-300 hover:scale-[1.02]"
      >
        {vertical.primaryCtaLabel}
      </a>
    </div>
  </div>
</section>

<TechAuthority
  title="Si la web empieza a generar flujo, la automatizacion puede crecer despues"
  description="WhatsApp, formularios, CRM, seguimiento y reportes se conectan cuando ya hay una ruta comercial clara. Empezamos simple para vender antes y escalar con criterio."
/>
