---
import {
  Mail,
  Phone,
  MapPin,
  Instagram,
  Linkedin,
  Twitter,
} from "lucide-react";
import ContactForm from "./ContactForm";

const INSTAGRAM_URL =
  import.meta.env.PUBLIC_INSTAGRAM_URL ||
  "https://www.instagram.com/jssolutions.com.co/";
const X_URL = import.meta.env.PUBLIC_X_URL || "https://x.com/jssolutions_co";
---

<footer
  id="contact"
  data-track-section="contact"
  class="bg-brand-black border-t border-white/5 pt-24 pb-12 relative overflow-hidden"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-brand-gold/50 to-transparent"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-20 items-center">
      <div>
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-white mb-6">
          Hablemos de <span class="text-brand-gold">Futuro</span>
        </h2>
        <p
          class="text-brand-off-white/70 text-lg mb-10 max-w-md leading-relaxed"
        >
          ¿Listo para escalar tu empresa con IA? Déjanos tus datos y te
          contactaremos para un diagnóstico gratuito de viabilidad y costos.
        </p>

        <div class="space-y-8">
          <div class="flex items-center gap-5 text-brand-off-white/90 group">
            <div
              class="p-4 bg-white/5 rounded-2xl text-brand-gold border border-white/5 group-hover:border-brand-gold/30 transition-colors"
            >
              <Mail className="w-6 h-6" />
            </div>
            <span class="text-lg">contacto@jssolutions.co</span>
          </div>
          <div class="flex items-center gap-5 text-brand-off-white/90 group">
            <div
              class="p-4 bg-white/5 rounded-2xl text-brand-gold border border-white/5 group-hover:border-brand-gold/30 transition-colors"
            >
              <Phone className="w-6 h-6" />
            </div>
            <span class="text-lg">+57 318 611 07 90</span>
          </div>
          <div class="flex items-center gap-5 text-brand-off-white/90 group">
            <div
              class="p-4 bg-white/5 rounded-2xl text-brand-gold border border-white/5 group-hover:border-brand-gold/30 transition-colors"
            >
              <MapPin className="w-6 h-6" />
            </div>
            <span class="text-lg">Cali, Colombia</span>
          </div>
        </div>
      </div>

      <ContactForm client:load />
    </div>

    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <a
        href="/"
        class="text-2xl font-bold font-heading text-white tracking-tight"
      >
        JS <span class="text-brand-gold">Solutions</span>
      </a>
      <div class="text-brand-off-white/40 text-sm font-light">
        © {new Date().getFullYear()} JS Solutions. Inteligencia Artificial.
      </div>
      <div class="flex gap-6">
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-off-white/60 hover:text-brand-gold transition-colors hover:scale-110 transform"
          aria-label="Síguenos en Instagram"
          ><Instagram className="w-5 h-5" /></a
        >
        <a
          href="https://www.linkedin.com/company/js-solutions-sas"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-off-white/60 hover:text-brand-gold transition-colors hover:scale-110 transform"
          aria-label="Síguenos en LinkedIn"><Linkedin className="w-5 h-5" /></a
        >
        <a
          href={X_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-off-white/60 hover:text-brand-gold transition-colors hover:scale-110 transform"
          aria-label="Síguenos en Twitter"><Twitter className="w-5 h-5" /></a
        >
      </div>
    </div>
  </div>
</footer>
