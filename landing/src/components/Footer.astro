---
import {
  Mail,
  Phone,
  MapPin,
  Instagram,
  Linkedin,
  Twitter,
} from "lucide-react";

const API_BASE_URL =
  import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:3003";
const INSTAGRAM_URL =
  import.meta.env.PUBLIC_INSTAGRAM_URL || "https://www.instagram.com/jssolutions.co/";
const X_URL = import.meta.env.PUBLIC_X_URL || "https://x.com/jssolutions_co";
---

<footer
  id="contact"
  data-track-section="contact"
  class="bg-brand-black border-t border-white/5 pt-24 pb-12 relative overflow-hidden"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-brand-gold/50 to-transparent"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-20 items-center">
      <div>
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-white mb-6">
          Hablemos de <span class="text-brand-gold">Futuro</span>
        </h2>
        <p
          class="text-brand-off-white/70 text-lg mb-10 max-w-md leading-relaxed"
        >
          ¿Listo para escalar tu empresa con IA? Déjanos tus datos y te
          contactaremos para un diagnóstico gratuito de viabilidad y costos.
        </p>

        <div class="space-y-8">
          <div class="flex items-center gap-5 text-brand-off-white/90 group">
            <div
              class="p-4 bg-white/5 rounded-2xl text-brand-gold border border-white/5 group-hover:border-brand-gold/30 transition-colors"
            >
              <Mail className="w-6 h-6" />
            </div>
            <span class="text-lg">contacto@jssolutions.co</span>
          </div>
          <div class="flex items-center gap-5 text-brand-off-white/90 group">
            <div
              class="p-4 bg-white/5 rounded-2xl text-brand-gold border border-white/5 group-hover:border-brand-gold/30 transition-colors"
            >
              <Phone className="w-6 h-6" />
            </div>
            <span class="text-lg">+57 318 611 07 90</span>
          </div>
          <div class="flex items-center gap-5 text-brand-off-white/90 group">
            <div
              class="p-4 bg-white/5 rounded-2xl text-brand-gold border border-white/5 group-hover:border-brand-gold/30 transition-colors"
            >
              <MapPin className="w-6 h-6" />
            </div>
            <span class="text-lg">Cali, Colombia</span>
          </div>
        </div>
      </div>

      <form
        id="contactForm"
        class="space-y-6 bg-white/5 p-8 md:p-10 rounded-3xl border border-white/10 backdrop-blur-sm shadow-2xl relative"
      >
        <div
          class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent rounded-3xl pointer-events-none"
        >
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
          <div class="space-y-2">
            <label
              for="name"
              class="text-xs font-bold text-brand-gold uppercase tracking-wider ml-2"
              >Nombre</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Tu Nombre"
              class="w-full bg-brand-black/50 border border-white/10 rounded-xl px-5 py-4 text-white focus:border-brand-gold/50 focus:ring-1 focus:ring-brand-gold/50 focus:outline-none transition-all placeholder:text-white/20"
            />
          </div>
          <div class="space-y-2">
            <label
              for="email"
              class="text-xs font-bold text-brand-gold uppercase tracking-wider ml-2"
              >Email</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="correo@empresa.com"
              class="w-full bg-brand-black/50 border border-white/10 rounded-xl px-5 py-4 text-white focus:border-brand-gold/50 focus:ring-1 focus:ring-brand-gold/50 focus:outline-none transition-all placeholder:text-white/20"
            />
          </div>
        </div>

        <div class="space-y-2 relative z-10">
          <label
            for="company"
            class="text-xs font-bold text-brand-gold uppercase tracking-wider ml-2"
            >Empresa</label
          >
          <input
            type="text"
            id="company"
            name="company"
            placeholder="Nombre de tu organización"
            class="w-full bg-brand-black/50 border border-white/10 rounded-xl px-5 py-4 text-white focus:border-brand-gold/50 focus:ring-1 focus:ring-brand-gold/50 focus:outline-none transition-all placeholder:text-white/20"
          />
        </div>

        <div class="space-y-2 relative z-10">
          <label
            for="message"
            class="text-xs font-bold text-brand-gold uppercase tracking-wider ml-2"
            >Mensaje</label
          >
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            placeholder="¿Qué proceso te gustaría automatizar?"
            class="w-full bg-brand-black/50 border border-white/10 rounded-xl px-5 py-4 text-white focus:border-brand-gold/50 focus:ring-1 focus:ring-brand-gold/50 focus:outline-none transition-all resize-none placeholder:text-white/20"
          ></textarea>
        </div>

        <button
          type="submit"
          id="submitButton"
          data-track="lead_submit_click"
          data-track-label="Contact Form Submit"
          data-track-location="contact_form"
          class="relative z-10 w-full bg-gold-gradient text-black font-bold py-4 rounded-xl hover:shadow-[0_0_20px_rgba(212,175,55,0.4)] transition-all transform hover:scale-[1.02] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Solicitar Diagnóstico Gratuito
        </button>
        <p class="relative z-10 text-xs text-brand-off-white/60">
          Respuesta en menos de 24 horas habiles. No compartimos tus datos con
          terceros.
        </p>
        <p
          id="formFeedback"
          class="relative z-10 text-sm hidden rounded-xl px-4 py-3"
          aria-live="polite"
        ></p>
      </form>

      <script define:vars={{ API_BASE_URL }}>
        const form = document.getElementById("contactForm") as HTMLFormElement;
        const submitButton = document.getElementById(
          "submitButton",
        ) as HTMLButtonElement;
        const formFeedback = document.getElementById("formFeedback");
        const tracker = (window as any).__jsTrack;

        const setFeedback = (message: string, variant: "ok" | "error") => {
          if (!formFeedback) return;
          formFeedback.classList.remove(
            "hidden",
            "bg-red-500/15",
            "text-red-200",
            "border",
            "border-red-300/20",
            "bg-emerald-500/15",
            "text-emerald-200",
            "border-emerald-300/20",
          );

          if (variant === "ok") {
            formFeedback.classList.add(
              "bg-emerald-500/15",
              "text-emerald-200",
              "border",
              "border-emerald-300/20",
            );
          } else {
            formFeedback.classList.add(
              "bg-red-500/15",
              "text-red-200",
              "border",
              "border-red-300/20",
            );
          }
          formFeedback.textContent = message;
        };

        let formStarted = false;
        form?.addEventListener("focusin", () => {
          if (formStarted) return;
          formStarted = true;
          tracker?.track?.("lead_form_start", { form_id: "contact_form" });
        });

        form?.addEventListener("submit", async (e) => {
          e.preventDefault();
          tracker?.track?.("lead_form_submit_attempt", {
            form_id: "contact_form",
          });
          if (formFeedback) formFeedback.classList.add("hidden");

          // Disable button
          if (submitButton) {
            submitButton.disabled = true;
            submitButton.innerText = "Enviando...";
          }

          const formData = new FormData(form);
          const data = {
            name: formData.get("name"),
            email: formData.get("email"),
            company: formData.get("company"),
            message: formData.get("message"),
          };
          const trackingMeta = tracker?.getLeadPayloadMeta?.() || {};

          try {
            const response = await fetch(
              `${API_BASE_URL.replace(/\/$/, "")}/api/v1/public/leads/intake`,
              {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                },
                body: JSON.stringify({
                  fullName: data.name,
                  companyName: data.company || "Prospecto web",
                  email: data.email,
                  serviceInterest: "Contacto general",
                  notes: data.message,
                  source: "landing_contact_form",
                  utm: trackingMeta.utm || {},
                  landingPath: trackingMeta.landingPath || "",
                  referrer: trackingMeta.referrer || "",
                  correlationId: trackingMeta.correlationId || undefined,
                }),
              },
            );

            if (response.ok) {
              tracker?.track?.("lead_submitted", { form_id: "contact_form" });
              setFeedback(
                "Listo. Recibimos tu solicitud y te contactaremos en menos de 24 horas habiles.",
                "ok",
              );
              form.reset();
            } else {
              tracker?.track?.("lead_submit_error", {
                form_id: "contact_form",
                status_code: response.status,
              });
              throw new Error("Error en el envío");
            }
          } catch (error) {
            console.error(error);
            setFeedback(
              "Hubo un error al enviar el formulario. Intenta de nuevo en unos minutos o escribenos por WhatsApp.",
              "error",
            );
          } finally {
            // Re-enable button
            if (submitButton) {
              submitButton.disabled = false;
              submitButton.innerText = "Solicitar Diagnóstico Gratuito";
            }
          }
        });
      </script>
    </div>

    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <a
        href="/"
        class="text-2xl font-bold font-heading text-white tracking-tight"
      >
        JS <span class="text-brand-gold">Solutions</span>
      </a>
      <div class="text-brand-off-white/40 text-sm font-light">
        © {new Date().getFullYear()} JS Solutions. Inteligencia Artificial.
      </div>
      <div class="flex gap-6">
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-off-white/60 hover:text-brand-gold transition-colors hover:scale-110 transform"
          aria-label="Síguenos en Instagram"
          ><Instagram className="w-5 h-5" /></a
        >
        <a
          href="https://www.linkedin.com/company/js-solutions-sas"
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-off-white/60 hover:text-brand-gold transition-colors hover:scale-110 transform"
          aria-label="Síguenos en LinkedIn"><Linkedin className="w-5 h-5" /></a
        >
        <a
          href={X_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-off-white/60 hover:text-brand-gold transition-colors hover:scale-110 transform"
          aria-label="Síguenos en Twitter"><Twitter className="w-5 h-5" /></a
        >
      </div>
    </div>
  </div>
</footer>
