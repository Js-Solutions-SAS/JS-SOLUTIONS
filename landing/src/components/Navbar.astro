---
import { Menu } from "lucide-react";
---

<nav
  class="fixed top-0 w-full z-50 transition-all duration-300 bg-brand-black/80 backdrop-blur-md border-b border-white/5"
>
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/logo.svg"
        alt="JS Solutions Logo"
        class="h-12 w-auto transition-transform duration-300 group-hover:scale-105"
      />
      <span class="text-xl font-bold font-heading text-white tracking-tight">
        JS <span class="text-transparent bg-clip-text bg-gold-gradient"
          >Solutions</span
        >
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8 text-brand-off-white">
      <a
        href="#about"
        class="text-sm font-medium hover:text-brand-gold transition-colors"
        >Nosotros</a
      >
      <a
        href="#services"
        class="text-sm font-medium hover:text-brand-gold transition-colors"
        >Servicios</a
      >
      <a
        href="#solutions"
        class="text-sm font-medium hover:text-brand-gold transition-colors"
        >Soluciones</a
      >
      <a
        href="#contact"
        class="px-6 py-2.5 bg-gold-gradient text-black font-bold text-sm rounded-full transition-all transform hover:scale-105 hover:shadow-[0_0_15px_rgba(212,175,55,0.3)]"
      >
        Diagnóstico Gratuito
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden text-white hover:text-brand-gold transition-colors relative z-50"
      aria-label="Menu"
    >
      <Menu className="w-8 h-8" client:visible />
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-brand-black/95 backdrop-blur-xl z-40 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col items-center justify-center gap-8 opacity-0"
  >
    <a
      href="#about"
      class="mobile-link text-2xl font-bold text-white hover:text-brand-gold transition-colors"
      >Nosotros</a
    >
    <a
      href="#services"
      class="mobile-link text-2xl font-bold text-white hover:text-brand-gold transition-colors"
      >Servicios</a
    >
    <a
      href="#solutions"
      class="mobile-link text-2xl font-bold text-white hover:text-brand-gold transition-colors"
      >Soluciones</a
    >
    <a
      href="#contact"
      class="mobile-link px-8 py-3 bg-gold-gradient text-black font-bold text-xl rounded-full hover:scale-105 transition-transform"
    >
      Diagnóstico Gratuito
    </a>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const menuOverlay = document.getElementById("mobile-menu-overlay");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      menuOverlay?.classList.remove("translate-x-full", "opacity-0");
      menuOverlay?.classList.add("translate-x-0", "opacity-100");
      document.body.style.overflow = "hidden"; // Prevent scrolling
    } else {
      menuOverlay?.classList.add("translate-x-full", "opacity-0");
      menuOverlay?.classList.remove("translate-x-0", "opacity-100");
      document.body.style.overflow = "";
    }
  }

  menuBtn?.addEventListener("click", toggleMenu);

  // Close menu when clicking a link
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });
</script>
