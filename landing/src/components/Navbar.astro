---
interface Props {
  activePath?: string;
  ctaHref?: string;
  ctaLabel?: string;
  ctaTrack?: string;
  ctaTrackLabel?: string;
  ctaTrackLocation?: string;
}

const {
  activePath = Astro.url.pathname,
  ctaHref = "/pymes",
  ctaLabel = "Explorar Soluciones",
  ctaTrack = "nav_cta_click",
  ctaTrackLabel = ctaLabel,
  ctaTrackLocation = "navbar",
} = Astro.props;

const normalizedPath = activePath.replace(/\/+$/, "") || "/";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/pymes", label: "PyMES" },
  { href: "/sector-publico", label: "Sector Publico" },
  { href: "/cotizador", label: "Cotizador" },
];
---

<nav class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-brand-black/78 backdrop-blur-xl">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
    <a
      href="/"
      data-track="nav_logo_click"
      data-track-label="Logo"
      data-track-location="navbar"
      class="flex items-center gap-3"
    >
      <img
        src="/logo.svg"
        alt="JS Solutions Logo"
        class="h-11 w-auto"
        width="64"
        height="64"
      />
      <span class="text-lg font-bold tracking-tight text-white md:text-xl">
        JS <span class="text-transparent bg-clip-text bg-gold-gradient">Solutions</span>
      </span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {
        links.map((link) => {
          const isActive = normalizedPath === link.href;
          return (
            <a
              href={link.href}
              data-track="nav_click"
              data-track-label={link.label}
              data-track-location="navbar_desktop"
              class:list={[
                "text-sm font-semibold transition-colors duration-300",
                isActive ? "text-brand-gold" : "text-brand-off-white/78 hover:text-white",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }

      <a
        href={ctaHref}
        data-track={ctaTrack}
        data-track-label={ctaTrackLabel}
        data-track-location={ctaTrackLocation}
        class="inline-flex items-center justify-center rounded-full bg-gold-gradient px-6 py-3 text-sm font-black uppercase tracking-[0.16em] text-black transition-transform duration-300 hover:scale-[1.02]"
      >
        {ctaLabel}
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="relative z-50 inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 text-white transition-colors duration-300 hover:border-brand-gold/50 hover:text-brand-gold md:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu-overlay"
      type="button"
    >
      <span class="sr-only">Abrir menu</span>
      <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu-overlay"
    class="pointer-events-none fixed inset-0 z-40 flex translate-x-full flex-col justify-between bg-brand-black/96 px-6 pb-10 pt-28 opacity-0 transition-[transform,opacity] duration-300 md:hidden"
  >
    <div class="space-y-5">
      {
        links.map((link) => {
          const isActive = normalizedPath === link.href;
          return (
            <a
              href={link.href}
              data-track="nav_click"
              data-track-label={link.label}
              data-track-location="navbar_mobile"
              class:list={[
                "mobile-link block text-3xl font-bold leading-none transition-colors duration-300",
                isActive ? "text-brand-gold" : "text-white",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>

    <a
      href={ctaHref}
      data-track={ctaTrack}
      data-track-label={ctaTrackLabel}
      data-track-location={`${ctaTrackLocation}_mobile`}
      class="mobile-link inline-flex items-center justify-center rounded-full bg-gold-gradient px-6 py-4 text-center text-sm font-black uppercase tracking-[0.16em] text-black"
    >
      {ctaLabel}
    </a>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const menuOverlay = document.getElementById("mobile-menu-overlay");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      menuOverlay?.classList.remove("translate-x-full", "opacity-0", "pointer-events-none");
      menuOverlay?.classList.add("translate-x-0", "opacity-100");
      menuBtn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    } else {
      menuOverlay?.classList.add("translate-x-full", "opacity-0", "pointer-events-none");
      menuOverlay?.classList.remove("translate-x-0", "opacity-100");
      menuBtn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }
  }

  menuBtn?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });
</script>
