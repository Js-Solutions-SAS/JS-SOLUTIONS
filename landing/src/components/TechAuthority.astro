---
import {
  homeAuthoritySignals,
  integrationBadges,
  type AuthoritySignal,
} from "@/data/sector-content";

interface Props {
  title?: string;
  description?: string;
  signals?: AuthoritySignal[];
}

const {
  title = "Integramos sin pedir que rehagas toda tu operacion",
  description = "WhatsApp, CRM, automatizacion, nube, voz y documentos pueden trabajar como un sistema mas ordenado. La tecnologia aqui reduce riesgo, no lo aumenta.",
  signals = homeAuthoritySignals,
} = Astro.props;
---

<section
  id="integraciones"
  data-track-section="tech_authority"
  class="relative border-y border-white/10 bg-brand-charcoal/55 py-20"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-8 md:grid-cols-[0.8fr_1.2fr] md:items-end">
      <div>
        <p class="text-[11px] font-black uppercase tracking-[0.34em] text-brand-gold/78">
          Compatibilidad real
        </p>
        <h2 class="mt-4 max-w-xl text-balance text-3xl font-bold leading-tight text-white md:text-5xl">
          {title}
        </h2>
      </div>
      <p class="max-w-2xl text-base leading-relaxed text-brand-off-white/72 md:justify-self-end md:text-lg">
        {description}
      </p>
    </div>

    <ul class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-6">
      {
        integrationBadges.map((tool) => (
          <li>
            <a
              href={tool.href}
              target="_blank"
              rel="noopener noreferrer"
              data-track="authority_tool_click"
              data-track-label={tool.name}
              data-track-location="tech_authority"
              class="group flex items-center gap-3 rounded-[1.35rem] border border-white/10 bg-brand-black/65 px-4 py-3 transition-colors duration-300 hover:border-brand-gold/40"
            >
              <img
                src={tool.logo}
                alt={`Logo ${tool.name}`}
                width="96"
                height="34"
                loading="lazy"
                decoding="async"
                class="h-8 w-20 shrink-0 object-contain"
              />
              <span class="text-xs font-semibold leading-tight text-brand-off-white/78 transition-colors duration-300 group-hover:text-white">
                {tool.name}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        signals.map((signal) => (
          <article class="border-t border-white/10 pt-5">
            <h3 class="text-sm font-black uppercase tracking-[0.22em] text-brand-gold">
              {signal.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-brand-off-white/70">
              {signal.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
