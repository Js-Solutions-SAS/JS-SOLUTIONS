---
import {
  homeAuthoritySignals,
  integrationBadges,
  type AuthoritySignal,
} from "@/data/sector-content";

interface Props {
  title?: string;
  description?: string;
  signals?: AuthoritySignal[];
}

const {
  title = "Integramos sin pedir que rehagas toda tu operacion",
  description = "WhatsApp, CRM, automatizacion, nube, voz y documentos pueden trabajar como un sistema mas ordenado. La tecnologia aqui reduce riesgo, no lo aumenta.",
  signals = homeAuthoritySignals,
} = Astro.props;
---

<section
  id="integraciones"
  data-track-section="tech_authority"
  class="relative border-y border-white/10 bg-brand-charcoal/55 py-20"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-8 md:grid-cols-[0.8fr_1.2fr] md:items-end">
      <div>
        <p class="text-[11px] font-black uppercase tracking-[0.34em] text-brand-gold/78">
          Compatibilidad real
        </p>
        <h2 class="mt-4 max-w-xl text-balance text-3xl font-bold leading-tight text-white md:text-5xl">
          {title}
        </h2>
      </div>
      <p class="max-w-2xl text-base leading-relaxed text-brand-off-white/72 md:justify-self-end md:text-lg">
        {description}
      </p>
    </div>

    <div class="mt-12" data-logo-carousel>
      <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 hidden w-12 bg-gradient-to-r from-brand-charcoal/90 to-transparent md:block">
        </div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 hidden w-12 bg-gradient-to-l from-brand-charcoal/90 to-transparent md:block">
        </div>

        <ul
          data-logo-track
          class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2"
          aria-label="Integraciones compatibles"
        >
          {
            integrationBadges.map((tool) => (
              <li class="min-w-[11rem] shrink-0 snap-start md:min-w-[12rem]" data-carousel-card>
                <a
                  href={tool.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Abrir ${tool.name}`}
                  title={tool.name}
                  data-track="authority_tool_click"
                  data-track-label={tool.name}
                  data-track-location="tech_authority"
                  class="group flex h-full items-center justify-center rounded-[1.35rem] border border-white/10 bg-brand-black/65 px-4 py-3 transition-colors duration-300 hover:border-white/22"
                  data-carousel-card-link
                >
                  <span class="flex h-10 w-full max-w-[7.5rem] shrink-0 items-center justify-center overflow-hidden rounded-lg border border-white/8 bg-white/[0.03] px-2 py-1.5">
                    <img
                      src={tool.logo}
                      alt={`Logo ${tool.name}`}
                      width="96"
                      height="34"
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-contain"
                      data-logo-mark
                    />
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mt-5 flex justify-end">
        <div class="flex items-center gap-2">
          <button
            type="button"
            aria-label="Ver integracion anterior"
            data-carousel-prev
            data-track="authority_carousel_click"
            data-track-label="Anterior"
            data-track-location="tech_authority"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-brand-black/70 text-brand-off-white/70 transition-colors duration-300 hover:border-brand-gold/45 hover:text-white"
          >
            <span aria-hidden="true">&larr;</span>
          </button>
          <button
            type="button"
            aria-label="Ver siguiente integracion"
            data-carousel-next
            data-track="authority_carousel_click"
            data-track-label="Siguiente"
            data-track-location="tech_authority"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-brand-black/70 text-brand-off-white/70 transition-colors duration-300 hover:border-brand-gold/45 hover:text-white"
          >
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
      </div>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        signals.map((signal) => (
          <article class="border-t border-white/10 pt-5">
            <h3 class="text-sm font-black uppercase tracking-[0.22em] text-brand-gold">
              {signal.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-brand-off-white/70">
              {signal.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  [data-logo-track] {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  [data-logo-track]::-webkit-scrollbar {
    display: none;
  }

  [data-logo-mark] {
    filter: grayscale(1) saturate(0.2) brightness(1.22) contrast(1.06);
    opacity: 0.9;
  }

  [data-carousel-card-link]:hover [data-logo-mark],
  [data-carousel-card-link]:focus-visible [data-logo-mark] {
    filter: grayscale(1) saturate(0.2) brightness(1.35) contrast(1.08);
    opacity: 1;
  }
</style>

<script>
  const GLOBAL_TIMER_KEY = "__jsLogoCarouselTimers";
  const GLOBAL_HOOK_KEY = "__jsLogoCarouselCleanupBound";

  const activeTimers =
    (window[GLOBAL_TIMER_KEY] instanceof Set
      ? window[GLOBAL_TIMER_KEY]
      : new Set());
  window[GLOBAL_TIMER_KEY] = activeTimers;

  if (!window[GLOBAL_HOOK_KEY]) {
    const clearGlobalTimers = () => {
      activeTimers.forEach((timerId) => window.clearInterval(timerId));
      activeTimers.clear();
    };

    document.addEventListener("astro:before-swap", clearGlobalTimers);
    window.addEventListener("pagehide", clearGlobalTimers);
    window[GLOBAL_HOOK_KEY] = true;
  }

  const carousels = document.querySelectorAll("[data-logo-carousel]");

  carousels.forEach((carousel) => {
    if (!(carousel instanceof HTMLElement) || carousel.dataset.carouselReady === "true") {
      return;
    }

    carousel.dataset.carouselReady = "true";

    const track = carousel.querySelector("[data-logo-track]");
    const prevButton = carousel.querySelector("[data-carousel-prev]");
    const nextButton = carousel.querySelector("[data-carousel-next]");

    if (!(track instanceof HTMLElement)) return;

    const getStepSize = () => {
      const firstCard = track.querySelector("[data-carousel-card]");
      if (!(firstCard instanceof HTMLElement)) return track.clientWidth * 0.78;

      const styles = window.getComputedStyle(track);
      const rawGap = styles.columnGap || styles.gap || "16";
      const parsedGap = Number.parseFloat(rawGap);
      const gap = Number.isFinite(parsedGap) ? parsedGap : 16;

      return firstCard.getBoundingClientRect().width + gap;
    };

    const move = (direction) => {
      const step = getStepSize();
      const maxLeft = Math.max(track.scrollWidth - track.clientWidth, 0);
      const nearEnd = track.scrollLeft >= maxLeft - step * 0.45;
      const nearStart = track.scrollLeft <= step * 0.45;

      if (direction > 0 && nearEnd) {
        track.scrollTo({ left: 0, behavior: "smooth" });
        return;
      }

      if (direction < 0 && nearStart) {
        track.scrollTo({ left: maxLeft, behavior: "smooth" });
        return;
      }

      track.scrollBy({
        left: step * direction,
        behavior: "smooth",
      });
    };

    const AUTOPLAY_DELAY_MS = 3600;
    let autoplayId;

    const stopAutoplay = () => {
      if (!autoplayId) return;
      window.clearInterval(autoplayId);
      activeTimers.delete(autoplayId);
      autoplayId = undefined;
    };

    const startAutoplay = () => {
      stopAutoplay();
      autoplayId = window.setInterval(() => move(1), AUTOPLAY_DELAY_MS);
      activeTimers.add(autoplayId);
    };

    prevButton?.addEventListener("click", () => {
      move(-1);
      startAutoplay();
    });

    nextButton?.addEventListener("click", () => {
      move(1);
      startAutoplay();
    });

    carousel.addEventListener("pointerenter", stopAutoplay);
    carousel.addEventListener("pointerleave", startAutoplay);
    carousel.addEventListener("focusin", stopAutoplay);
    carousel.addEventListener("focusout", startAutoplay);
    carousel.addEventListener("touchstart", stopAutoplay, { passive: true });
    carousel.addEventListener("touchend", startAutoplay);

    startAutoplay();
  });
</script>
