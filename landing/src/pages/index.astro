---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import HomeHero from "../components/HomeHero.astro";
import LocalBusinessPathways from "../components/LocalBusinessPathways.astro";
import Navbar from "../components/Navbar.astro";
import SectorPathways from "../components/SectorPathways.astro";
import TechAuthority from "../components/TechAuthority.astro";
import WebPackages from "../components/WebPackages.astro";
---

<Layout
  title="JS Solutions | Webs Simples y Automatización con 40% OFF"
  description="Creamos landings, páginas web simples y automatización ligera con 40% de descuento por tiempo limitado. Ideal para restaurantes, clínicas y negocios locales en Colombia."
  keywords="promocion paginas web, paginas web con descuento, landing pages Colombia, webs para restaurantes, automatizacion WhatsApp, JS Solutions"
>
  <Navbar />
  <main class="relative overflow-hidden bg-brand-black">
    <HomeHero />
    <LocalBusinessPathways />
    <WebPackages location="home_packages" />
    <SectorPathways />
    <TechAuthority />
  </main>
  <Footer />
</Layout>
