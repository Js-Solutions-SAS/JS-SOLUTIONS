---
import Layout from "../layouts/Layout.astro";
import CotizadorInteractivo from "../components/CotizadorInteractivo";

const API_BASE_URL =
  import.meta.env.PUBLIC_API_BASE_URL ||
  (import.meta.env.PROD
    ? "https://api.jssolutions.com.co"
    : "http://localhost:3003");
---

<Layout
  title="Cotizador - JS SOLUTIONS"
  description="Obtén una estimación inicial de alcance y presupuesto para tu proyecto de IA y automatización."
>
  <main
    data-track-section="cotizador_page"
    class="min-h-screen bg-gray-50 dark:bg-zinc-950 py-16 px-4"
  >
    <div class="max-w-3xl mx-auto">
      <CotizadorInteractivo client:load apiBaseUrl={API_BASE_URL} />
    </div>
  </main>
</Layout>
