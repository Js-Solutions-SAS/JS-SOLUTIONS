# Required for local admin authentication
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD_HASH=
AUTH_SESSION_SECRET=
# Optional. If omitted, AUTH_SESSION_SECRET is reused for CSRF token signing.
AUTH_CSRF_SECRET=

# Generate a password hash (run inside /admin):
# node -e "const argon2=require('argon2');argon2.hash('replace-with-strong-password',{type:argon2.argon2id,memoryCost:65536,timeCost:3,parallelism:1}).then(console.log)"

# Generate a 32+ chars secret:
# openssl rand -base64 48
