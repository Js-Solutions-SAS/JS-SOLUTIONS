    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst leadId = body.leadId ?? body.quoteId ?? '';\nconst email = body.email ?? '';\n\nif (!leadId && !email) {\n  throw new Error('leadId or email is required');\n}\n\nreturn [{\n  json: {\n    leadId,\n    email,\n    requestedAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "62b7d5bf-d5d6-4f43-ac48-48f60bc9fa5b",
      "name": "Validate Request",
      "type": "n8n-nodes-base.code",
