    {
      "parameters": {
        "jsCode": "const request = $('Validate Request').item.json;\nconst row = $json ?? {};\nconst portalBaseUrl = 'https://portal.jssolutions.com.co';\nconst existingToken = row.Brief_Token ?? row.briefToken ?? '';\nconst token = existingToken || (typeof crypto !== 'undefined' && crypto.randomUUID\n  ? crypto.randomUUID()\n  : `${Date.now()}-${Math.random().toString(16).slice(2)}`);\nconst briefUrl = row.Brief_URL || row.briefUrl || `${portalBaseUrl}/brief/${token}`;\nconst clientDashboardUrl = row.Client_Dashboard_URL || row.clientDashboardUrl || `${portalBaseUrl}/dashboard?token=${token}`;\nconst email = request.email || row.email || row.Prospect_Email || '';\nconst leadId = request.leadId || row.leadId || row.id || '';\nconst previousKey = row.Last_Request_Brief_Idempotency_Key || '';\nconst skipEmail = !request.forceResend && Boolean(request.idempotencyKey && previousKey && previousKey === request.idempotencyKey);\nconst deliveryStatus = skipEmail ? 'skipped_idempotent' : 'sent';\n\nreturn [{\n  json: {\n    leadId,\n    email,\n    token,\n    briefUrl,\n    clientDashboardUrl,\n    requestedAt: request.requestedAt,\n    nextStatus: 'Brief Enviado',\n    idempotencyKey: request.idempotencyKey,\n    correlationId: request.correlationId,\n    requestId: request.requestId,\n    forceResend: request.forceResend,\n    skipEmail,\n    deliveryStatus\n  }\n}];"
      },
