    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst leadId = body.leadId ?? body.quoteId ?? '';\nconst email = body.email ?? '';\nconst idempotencyKey = body.idempotencyKey ?? '';\nconst correlationId = body.correlationId ?? `req-brief-${Date.now()}`;\nconst requestId = body.requestId ?? body.idempotencyKey ?? `req-brief-${Date.now()}`;\nconst forceResend = Boolean(body.forceResend);\n\nif (!leadId && !email) {\n  throw new Error('leadId or email is required');\n}\n\nreturn [{\n  json: {\n    leadId,\n    email,\n    requestedAt: new Date().toISOString(),\n    idempotencyKey,\n    correlationId,\n    requestId,\n    forceResend\n  }\n}];"
      },
      "id": "62b7d5bf-d5d6-4f43-ac48-48f60bc9fa5b",
      "name": "Validate Request",
      "type": "n8n-nodes-base.code",
