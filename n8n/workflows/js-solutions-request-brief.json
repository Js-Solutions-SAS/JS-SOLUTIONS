    {
      "parameters": {
        "jsCode": "const request = $('Validate Request').item.json;\nconst row = $json ?? {};\nconst portalBaseUrl = 'https://portal.jssolutions.com.co';\nconst existingToken = row.Brief_Token ?? row.briefToken ?? '';\nconst token = existingToken || (typeof crypto !== 'undefined' && crypto.randomUUID\n  ? crypto.randomUUID()\n  : `${Date.now()}-${Math.random().toString(16).slice(2)}`);\nconst briefUrl = row.Brief_URL || row.briefUrl || `${portalBaseUrl}/brief/${token}`;\nconst clientDashboardUrl = row.Client_Dashboard_URL || row.clientDashboardUrl || `${portalBaseUrl}/dashboard?token=${token}`;\nconst email = request.email || row.email || row.Prospect_Email || '';\nconst leadId = request.leadId || row.leadId || row.id || '';\n\nreturn [{\n  json: {\n    leadId,\n    email,\n    token,\n    briefUrl,\n    clientDashboardUrl,\n    requestedAt: request.requestedAt,\n    nextStatus: 'Brief Enviado'\n  }\n}];"
      },
      "id": "be973217-2858-4b30-bfcb-bc33b0dc3a3a",
