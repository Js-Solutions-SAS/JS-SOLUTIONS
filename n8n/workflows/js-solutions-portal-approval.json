    {
      "parameters": {
        "jsCode": "const row = $json ?? {};\nconst request = $('Validate Approval Request').item.json;\nconst expectedQuoteId = row.Quote_Document_Id ?? '';\nconst expectedContractId = row.Contract_Document_Id ?? `contract-${row.leadId || ''}`;\n\nif (!row.leadId) {\n  throw new Error('lead not found for clientToken');\n}\n\nif (request.resourceType === 'quote' && expectedQuoteId && expectedQuoteId !== request.resourceId) {\n  throw new Error('resourceId does not match Quote_Document_Id');\n}\n\nif (request.resourceType === 'contract' && expectedContractId && expectedContractId !== request.resourceId) {\n  throw new Error('resourceId does not match Contract_Document_Id');\n}\n\nreturn [{\n  json: {\n    leadId: row.leadId,\n    clientToken: request.clientToken,\n    resourceType: request.resourceType,\n    resourceId: request.resourceId,\n    resourceName: request.resourceName,\n    approvedAt: request.approvedAt,\n    correlationId: request.correlationId,\n    idempotencyKey: request.idempotencyKey,\n    currentQuoteStatus: row.Quote_Status ?? '',\n    currentQuoteApprovedAt: row.Quote_Approved_At ?? '',\n    currentContractStatus: row.Contract_Status ?? '',\n    currentContractApprovedAt: row.Contract_Approved_At ?? '',\n    currentEstado: row.estado ?? ''\n  }\n}];"
      },
