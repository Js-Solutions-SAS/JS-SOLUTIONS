        "jsCode": "const row = $json ?? {};\nconst request = $('Validate Approval Request').item.json;\nconst expectedId = row.Quote_Document_Id ?? '';\n\nif (!row.leadId) {\n  throw new Error('lead not found for clientToken');\n}\n\nif (expectedId && expectedId !== request.resourceId) {\n  throw new Error('resourceId does not match Quote_Document_Id');\n}\n\nreturn [{\n  json: {\n    leadId: row.leadId,\n    clientToken: request.clientToken,\n    resourceId: request.resourceId,\n    resourceName: request.resourceName,\n    approvedAt: request.approvedAt\n  }\n}];"
