      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst clientToken = body.clientToken ?? '';\nconst resourceTypeRaw = body.resourceType ?? 'deliverable';\nconst resourceType = ['quote', 'contract', 'deliverable'].includes(resourceTypeRaw)\n  ? resourceTypeRaw\n  : 'deliverable';\nconst resourceId = body.resourceId ?? body.documentId ?? '';\nconst resourceName = body.resourceName ?? body.documentName ?? 'Entregable';\nconst approvedAt = body.approvedAt ?? new Date().toISOString();\nconst correlationId = body.correlationId ?? '';\nconst idempotencyKey = body.idempotencyKey ?? '';\n\nif (!clientToken || !resourceId) {\n  throw new Error('clientToken and resourceId are required');\n}\n\nreturn [{\n  json: {\n    clientToken,\n    resourceType,\n    resourceId,\n    resourceName,\n    approvedAt,\n    correlationId,\n    idempotencyKey\n  }\n}];"
      },
