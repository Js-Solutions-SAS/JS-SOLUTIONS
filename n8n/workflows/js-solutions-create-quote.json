    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst now = new Date();\nconst leadId = body.leadId || body.quoteId || `lead-${Date.now()}`;\nconst token = typeof crypto !== 'undefined' && crypto.randomUUID\n  ? crypto.randomUUID()\n  : `${Date.now()}-${Math.random().toString(16).slice(2)}`;\nconst portalBaseUrl = 'https://portal.jssolutions.com.co';\nconst services = Array.isArray(body.servicios)\n  ? body.servicios\n  : Array.isArray(body.services)\n    ? body.services\n    : [];\nconst amount = body.monto || body.amount || '$0';\nconst details = body.detalles || body.details || '';\nconst briefUrl = `${portalBaseUrl}/brief/${token}`;\nconst clientDashboardUrl = `${portalBaseUrl}/dashboard?token=${token}`;\n\nreturn [{\n  json: {\n    leadId,\n    nombre: body.nombre || body.name || 'Sin nombre',\n    empresa: body.empresa || body.company || 'Empresa no especificada',\n    email: body.email || body.Prospect_Email || '',\n    servicio: body.servicio || body.service || 'Sin servicio',\n    monto: amount,\n    industria: body.industria || body.industry || 'General',\n    detalles: details,\n    sector: body.sector || '',\n    complejidad: body.complejidad || body.complexity || '',\n    servicios: JSON.stringify(services),\n    serviciosTexto: services.join(', '),\n    rangoMin: body.rangoInversion?.min ?? body.rangoMin ?? 0,\n    rangoMax: body.rangoInversion?.max ?? body.rangoMax ?? 0,\n    estado: body.estado || 'Diagnóstico Capturado',\n    createdAt: now.toISOString(),\n    Brief_Token: token,\n    Brief_URL: briefUrl,\n    Client_Dashboard_URL: clientDashboardUrl,\n    briefUrl,\n    clientDashboardUrl\n  }\n}];"
      },
