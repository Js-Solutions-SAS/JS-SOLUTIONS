    {
      "parameters": {
        "jsCode": "const source = $json;\nconst req = $('Validate Contract Request').item.json;\nconst leadId = source.leadId ?? req.leadId;\nconst email = source.email ?? req.email;\nconst contractId = typeof crypto !== 'undefined' && crypto.randomUUID\n  ? crypto.randomUUID()\n  : `${Date.now()}-${Math.random().toString(16).slice(2)}`;\nconst company = source.empresa ?? source.Empresa ?? 'Prospecto';\nconst service = source.servicio ?? source.Servicio ?? 'Servicio JS Solutions';\nconst amount = source.monto ?? source.Monto ?? 'Pendiente';\nconst contractUrl = `https://files.jssolutions.co/contracts/${contractId}.pdf`;\n\nreturn [{\n  json: {\n    leadId,\n    email,\n    empresa: company,\n    servicio: service,\n    monto: amount,\n    contractId,\n    contractUrl,\n    estado: 'Contrato Enviado',\n    Contract_URL: contractUrl,\n    Contract_Generated_At: new Date().toISOString(),\n    contractHtml: `<h1>Contrato JS Solutions</h1><p>Cliente: ${company}</p><p>Servicio: ${service}</p><p>Valor: ${amount}</p><p>ID: ${contractId}</p>`\n  }\n}];"
      },
      "id": "d482562b-f124-4a17-82be-d9ea60365853",
      "name": "Prepare Contract Payload",
