          "__rl": true,
          "value": "Hoja 1",
          "mode": "name"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "leadId",
              "lookupValue": "={{ $('Validate Contract Request').item.json.leadId }}"
            }
          ]
        },
        "options": {}
      },
      "id": "da4dcb35-b30d-4e4d-b6ea-1f67aca3f4ed",
      "name": "Lookup Lead Data",
