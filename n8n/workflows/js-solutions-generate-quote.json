    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst fallbackId = body.id ?? '';\nconst leadId = body.leadId ?? (fallbackId ? `lead-${fallbackId}` : '');\nconst clientToken = body.clientToken ?? body.token ?? body.Brief_Token ?? fallbackId ?? '';\nconst transcripcion = body.transcripcion ?? '';\nconst rawDatosCliente = body.datos_cliente ?? body.datosCliente ?? body.cliente ?? '';\n\nconst normalize = (value) => String(value ?? '').trim();\n\nconst extractClientName = (raw) => {\n  if (raw && typeof raw === 'object') {\n    const candidates = [\n      raw.nombre,\n      raw.name,\n      raw.empresa,\n      raw.company,\n      raw.razon_social,\n      raw.razonSocial,\n      raw.cliente,\n    ]\n      .map(normalize)\n      .filter(Boolean);\n\n    if (candidates.length) return candidates[0];\n  }\n\n  const text = normalize(raw);\n  if (!text) return '';\n\n  const labelled = text.match(/(?:^|[\\n|,;])\\s*(?:nombre(?: del cliente)?|cliente|empresa|raz[oó]n social)\\s*[:=-]\\s*([^\\n|,;]+)/i);\n  if (labelled?.[1]) return normalize(labelled[1]);\n\n  const ignored = /@|tel[eé]fono|celular|correo|email|whatsapp|nit|id\\b/i;\n  const segments = text\n    .split(/[\\n|,;]+/)\n    .map((segment) => segment.trim())\n    .filter(Boolean);\n\n  const selected = segments.find((segment) => !ignored.test(segment));\n  return selected ? selected.replace(/^(nombre|cliente|empresa)\\s*[:=-]\\s*/i, '').trim() : '';\n};\n\nconst nombreCliente = extractClientName(rawDatosCliente) || 'Cliente';\nconst datosCliente =\n  typeof rawDatosCliente === 'string'\n    ? rawDatosCliente\n    : [rawDatosCliente?.nombre, rawDatosCliente?.empresa, rawDatosCliente?.email]\n        .map((value) => String(value ?? '').trim())\n        .filter(Boolean)\n        .join(' | ');\n\n// Blindaje de marca: siempre JS SOLUTIONS\nconst datosProveedor = 'JS SOLUTIONS';\nconst feedback = body.feedback ?? '';\nconst mode = body.mode === 'preview' ? 'preview' : 'send';\nconst idempotencyKey = body.idempotencyKey ?? '';\nconst correlationId = body.correlationId ?? `generate-quote-${Date.now()}`;\n\nconst emailCandidates = [\n  typeof body.email === 'string' ? body.email.trim() : '',\n  typeof rawDatosCliente === 'object' && rawDatosCliente\n    ? String(rawDatosCliente.email ?? '').trim()\n    : '',\n  datosCliente.split('|').map((item) => item.trim()).find((item) => item.includes('@')) || '',\n];\nconst email = emailCandidates.find(Boolean) || '';\n\nif (!leadId || !clientToken || !transcripcion) {\n  throw new Error('leadId, clientToken and transcripcion are required');\n}\n\nreturn [{\n  json: {\n    leadId,\n    clientToken,\n    transcripcion,\n    nombre_cliente: nombreCliente,\n    datos_cliente: datosCliente,\n    datos_proveedor: datosProveedor,\n    feedback,\n    email,\n    mode,\n    idempotencyKey,\n    correlationId,\n    dashboardUrl: `https://portal.jssolutions.com.co/dashboard?token=${clientToken}`,\n    quoteDocumentId: `quote-${leadId}`,\n    generatedAt: new Date().toISOString()\n  }\n}];"
      },
