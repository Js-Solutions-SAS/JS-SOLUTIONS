# Runtime
NODE_ENV=production
PORT=3000

# Shared secret for admin -> api internal calls
API_INTERNAL_TOKEN=CHANGE_ME

# Optional protection for /health/db (health remains public)
HEALTH_DB_PROTECTED=false

# Preferred single URL (EasyPanel internal)
DATABASE_URL=postgres://postgres:CHANGE_ME@agencia_js-solutions:5432/agencia?sslmode=disable

# Optional granular vars (used only if DATABASE_URL is not set)
DB_HOST=agencia_js-solutions
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=agencia
DB_SSL=false

# Upstream n8n orchestrations
N8N_REQUEST_TIMEOUT_MS=15000
N8N_GENERATE_QUOTE_TIMEOUT_MS=90000
N8N_REQUEST_BRIEF_WEBHOOK_URL=https://tu-n8n/webhook/js-solutions/request-brief
N8N_GENERATE_QUOTE_URL=https://tu-n8n/webhook/cotizador_js_solutions
N8N_GENERATE_CONTRACT_URL=https://tu-n8n/webhook/js-solutions/generate-contract
N8N_PAYMENTS_CREATE_WEBHOOK_URL=https://tu-n8n/webhook/js-solutions/payments/create
N8N_SECRET_TOKEN=

# Internal security hardening
INTERNAL_REQUIRE_HMAC_FOR_INTERNAL=true
INTERNAL_HMAC_SECRET=CHANGE_ME
INTERNAL_HMAC_MAX_SKEW_MS=300000
INTERNAL_IP_ALLOWLIST=

# Public API protection
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX_HITS=60

# Links used by lead/brief endpoints
PORTAL_BASE_URL=https://portal.jssolutions.com.co

# Meta Conversions API (server-side events)
META_CAPI_ENABLED=true
META_CAPI_API_VERSION=v22.0
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional: useful for Meta Events Manager "Test Events"
META_CAPI_TEST_EVENT_CODE=
